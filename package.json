{
  "name": "trustee-openshift-console-plugin",
  "version": "0.0.1",
  "description": "Deploy, manage, and observe the Red Hat build of Trustee — confidential containers attestation (KBS, attestation/resource policies, reference values, sealed secrets, and NVIDIA GPU attestation).",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/makentenza/trustee-openshift-console-plugin.git"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "yarn clean && NODE_ENV=production yarn webpack",
    "build-dev": "yarn clean && yarn webpack",
    "start": "yarn webpack serve --progress",
    "start-console": "./start-console.sh",
    "i18n": "./i18n-scripts/build-i18n.sh && node ./i18n-scripts/set-english-defaults.js",
    "test": "LANG=en_US.UTF-8 jest",
    "coverage": "jest --coverage",
    "lint": "yarn eslint src --fix && stylelint 'src/**/*.css' --allow-empty-input --fix",
    "webpack": "node -r ts-node/register ./node_modules/.bin/webpack",
    "deploy": "./deploy.sh"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@openshift-console/dynamic-plugin-sdk": "4.22-latest",
    "@openshift-console/dynamic-plugin-sdk-webpack": "4.22-latest",
    "@patternfly/react-core": "^6.4.3",
    "@patternfly/react-icons": "^6.4.0",
    "@patternfly/react-table": "^6.4.3",
    "@swc/core": "^1.15.40",
    "@swc/jest": "^0.2.39",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.28",
    "babel-loader": "^10.1.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^9.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "globals": "^17.6.0",
    "i18next": "^25.8.18",
    "i18next-parser": "^9.4.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "pluralize": "^8.0.0",
    "prettier": "^3.8.3",
    "prettier-stylelint": "^0.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "~16.5.8",
    "react-router": "~7.13.1",
    "style-loader": "^4.0.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "swc-loader": "^0.2.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.4"
  },
  "consolePlugin": {
    "name": "trustee-openshift-console-plugin",
    "version": "0.0.1",
    "displayName": "OpenShift Trustee Attestation",
    "description": "Deploy, manage, and observe the Red Hat build of Trustee confidential containers attestation service (KBS, policies, reference values, sealed secrets, GPU attestation).",
    "exposedModules": {
      "TrusteeTopology": "./components/TrusteeTopology",
      "TrusteeAttestation": "./components/TrusteeAttestation",
      "TrusteeActivity": "./components/TrusteeActivity",
      "TrusteeConfigRedirect": "./components/TrusteeConfigRedirect",
      "DeployTrusteeWizard": "./components/DeployTrusteeWizard",
      "TrusteePoliciesTab": "./components/tabs/TrusteePoliciesTab",
      "TrusteeReferenceValuesTab": "./components/tabs/TrusteeReferenceValuesTab",
      "TrusteeInitdataTab": "./components/tabs/TrusteeInitdataTab",
      "TrusteeSecretsTab": "./components/tabs/TrusteeSecretsTab",
      "TrusteeGpuTab": "./components/tabs/TrusteeGpuTab",
      "TrusteeHealthTab": "./components/tabs/TrusteeHealthTab",
      "ccActions": "./actions/ccActions"
    },
    "dependencies": {
      "@console/pluginAPI": "^4.22.0"
    }
  },
  "packageManager": "yarn@4.14.1"
}
